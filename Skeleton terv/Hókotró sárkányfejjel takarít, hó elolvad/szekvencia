@startuml
title Hókotró sárkányfejjel takarít, hó elolvad

actor Felhasználó as f
participant "sk: Skeleton" as sk
participant "t1: Takarito" as t1
participant "h1: Hokotro" as h1
participant "u1: Utszakasz" as u1
participant "sf1: sarkanyFej" as sf1

f -> sk : hokotroSarkanyFejTeszt()
activate sk
sk -> t1 : iranyit(u1)
activate t1
t1 -> h1 : halad(u1)
activate h1
h1 -> u1 : jarmuElore()
activate u1
u1 --> h1 : true
deactivate u1
h1 -> u1 : belep(h1)
activate u1
u1-->h1
deactivate u1
h1 -> sf1 : takarit(u1)
activate sf1
sf1 -> sf1 : kopas()
sf1 -> u1 : letakaritas()
activate u1
u1-->sf1
deactivate u1
sf1-->h1
deactivate sf1
h1 -> h1 : kopas()
h1 -> h1 : penztKeres()
h1 --> t1 : penztKap(osszeg)
deactivate h1
t1 --> sk
deactivate t1
sk --> f
deactivate sk
@enduml