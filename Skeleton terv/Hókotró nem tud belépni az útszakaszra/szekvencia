@startuml
title Hókotró nem tud belépni az útszakaszra

actor Felhasználó as jatekos
participant "sk: Skeleton" as sk
participant "h1: Hokotro" as h1
participant "u1: Utszakasz" as u1
participant "u2: Utszakasz" as u2

jatekos -> sk : hokotroNemTudBeplepniTeszt()
sk -> h1 : halad(u2)
activate h1
h1 -> u1 : jarmuElore()
activate u1
u1 -> u2 : foglaltE()
activate u2
u2 --> u1 : true
deactivate u2
u1 --> h1 : false
deactivate u1
h1 --> sk
deactivate h1
sk --> jatekos
@enduml