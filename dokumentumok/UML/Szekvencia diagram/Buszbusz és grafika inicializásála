@startuml
title Szekvenciadiagram: Busz és grafika inicializálása

actor Játékos
participant "menu: MainMenuView" as Menu
participant "b: Busz" as Busz
participant "v: Buszvezeto" as Vezeto
participant "view: BuszView" as View
participant "hud: BuszvezetoHUDView" as HUD
participant "ctrl: BuszController" as Ctrl

Játékos -> Menu : inditGomb lenyomva
activate Menu

Menu -> Busz : new Busz(...)
activate Busz
Busz --> Menu : b
deactivate Busz

Menu -> Vezeto : new Buszvezeto(...)
activate Vezeto
Vezeto --> Menu : v
deactivate Vezeto

Menu -> View : new BuszView(b)
activate View
View -> Busz : addObserver(this)
activate Busz
Busz --> View
deactivate Busz
View --> Menu : view
deactivate View

Menu -> HUD : new BuszvezetoHUDView(v)
activate HUD
HUD -> Vezeto : addObserver(this)
activate Vezeto
Vezeto --> HUD
deactivate Vezeto
HUD --> Menu : hud
deactivate HUD

Menu -> Ctrl : new BuszController(v)
activate Ctrl
Ctrl --> Menu : ctrl
deactivate Ctrl

deactivate Menu

@enduml
