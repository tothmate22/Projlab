@startuml
title Várakozás a javításra / Javítás vége (Busz ütközés után)

actor "Környezet\n(Óra)" as Ora
participant "b: Busz" as Busz
participant "cel: Utszakasz" as Utszakasz

Ora -> Busz: idoEltelt()
activate Busz

alt hatralevoJavitasiIdo > 0
    note right of Busz: A busz javítás alatt áll,\nezért a belső állapota frissül\n(a számláló csökken), de külső\npublikus hívás nem történik.
else hatralevoJavitasiIdo == 0
    Busz -> Busz: halad(cel)
    
    Busz -> Utszakasz: foglaltE()
    activate Utszakasz
    Utszakasz --> Busz: false
    deactivate Utszakasz
    
    Busz -> Utszakasz: belep(this)
    activate Utszakasz
    Utszakasz --> Busz
    deactivate Utszakasz
end

deactivate Busz
@enduml
