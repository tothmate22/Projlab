@startuml
title Busz és Buszvezető inicializálása (Játék indítása)

actor "Rendszer" as Main
participant "j: Jatek" as Jatek
participant "o: Ora" as Ora
participant "kezdo: Utszakasz" as Utszakasz
participant "v: Buszvezeto" as Vezeto
participant "b: Busz" as Busz

Main -> Jatek : init()
activate Jatek

Jatek -> Ora ** : <<create>>
Jatek -> Utszakasz ** : <<create>>

' Először a vezetőt hozzuk létre
Jatek -> Vezeto ** : <<create>>()

' Majd a buszt, átadva neki a vezetőt és a kezdő útszakaszt paraméterként
Jatek -> Busz ** : <<create>>(v, kezdo)

Jatek -> Utszakasz : belep(b)
activate Utszakasz
Utszakasz --> Jatek :
deactivate Utszakasz

Jatek -> Ora : addLepheto(b)
activate Ora
Ora --> Jatek :
deactivate Ora

Jatek --> Main :
deactivate Jatek
@enduml
