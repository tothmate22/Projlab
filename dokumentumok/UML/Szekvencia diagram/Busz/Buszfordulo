@startuml
title Célba érés és jutalom (Busz forduló)

actor "Környezet\n(Óra)" as Ora
participant "b: Busz" as Busz
participant "cel: Utszakasz" as Utszakasz
participant "v: Buszvezeto" as Buszvezeto

Ora -> Busz: idoEltelt()
activate Busz

Busz -> Busz: halad(cel)

Busz -> Utszakasz: foglaltE()
activate Utszakasz
Utszakasz --> Busz: false
deactivate Utszakasz

Busz -> Utszakasz: belep(this)
activate Utszakasz
Utszakasz --> Busz
deactivate Utszakasz

alt cel.getEpulet() == Epulet.MEGALLO
    Busz -> Busz: celbaErt()
    
    Busz -> Buszvezeto: penztKap(100)
    activate Buszvezeto
    Buszvezeto --> Busz
    deactivate Buszvezeto
end

deactivate Busz
@enduml
