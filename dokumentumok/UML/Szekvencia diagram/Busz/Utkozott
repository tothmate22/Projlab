@startuml
skinparam monochrome true
title Megcsúszás és ütközés (Use-case: Jármű csúsztatása)

actor "Környezet" as Kornyezet
participant "b: Busz" as Busz
participant "szomszed: Utszakasz" as Utszakasz
participant "masik: ICsuszhat" as Masik

note left of Busz
  A Környezet az ICsuszhat
  interfészen keresztül
  hívja a Buszt!
end note

Kornyezet -> Busz : kicsuszik()
activate Busz

Busz -> Utszakasz : foglaltE()
activate Utszakasz
Utszakasz --> Busz : true
deactivate Utszakasz

alt [szomszed.foglaltE() == true]
    Busz -> Masik : utkozott(b)
    activate Masik
    note right of Busz
      A busz hátralévő javítási
      ideje 1 órára állítódik.
    end note
    deactivate Masik

else [szomszed.foglaltE() == false]
    Busz -> Utszakasz : belep(this)
    activate Utszakasz
    deactivate Utszakasz

end

deactivate Busz
@enduml
