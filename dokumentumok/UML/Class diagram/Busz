@startuml
' Beállítások a BME-s analízis modell stílushoz
skinparam classAttributeIconSize 0
skinparam monochrome true

interface ILepheto {
  + idoEltelt(): void
}

interface ICsuszhat {
    + kicsuszik() : void
    + utkozott(masik : Jarmu) : void
}

enum UtTipus {
    NORMAL
    ALAGUT
    HID
    KERESZTEZODES
}

enum Epulet {
    MEGALLO
    HAZ
    MUNKAHELY
    BAZIS
}

abstract class Jarmu {
  - pozicio: Utszakasz
  + {abstract} halad(cel: Utszakasz): void
  + getPozicio(): Utszakasz
}

class Utszakasz {
    -ho : int
    -jeg : int
    -havonAthaladt : int
    -kozlekedoJarmu : Jarmu
    -felrehuzodottJarmu : Jarmu
    -szakaszElore : Utszakasz
    -szakaszBalra : Utszakasz
    -szakaszJobbra : Utszakasz
    +idojarasFrissites() : void
    +foglaltE() : boolean
    +foglaltSagValtoztatas(foglaltsag : boolean, jarmu : Jarmu) : void
}

Utszakasz o-- "1" UtTipus 
Utszakasz o-- "0..1" Epulet 

abstract class Jatekos {
  - nev: String
  - egyenleg: int
  + penztKap(osszeg: int): void
  + getEgyenleg(): int
}

class Buszvezeto {
  - sajatBusz: Busz
  + utvonalatValtoztat(ujCel: Utszakasz): void
}

class Busz {
  - celAllomas: Utszakasz
  - hatralevoJavitasiIdo: int
  - vezerlo: Buszvezeto
  + halad(cel: Utszakasz): void
  + utkozott(masik: Jarmu): void
  + kicsuszik(): void
  + celbaErt(): void
  + idoEltelt(): void
}

Jatekos <|-- Buszvezeto
Jarmu <|-- Busz

ILepheto <|.. Busz
ICsuszhat <|.. Busz

Busz "1" -right- "1" Buszvezeto 

' --- Nyilak a csapattárs stílusához igazítva ---
Jarmu --> "1" Utszakasz : pozicio >
Busz --> "1" Utszakasz : celAllomas >
Buszvezeto ..> Utszakasz : kijelöli >
@enduml
