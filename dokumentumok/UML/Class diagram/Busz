@startuml
' Beállítások a BME-s analízis modell stílushoz
skinparam classAttributeIconSize 0
skinparam monochrome true

interface ILepheto {
  + idoEltelt(): void
}

interface ICsuszhat {
    + kicsuszik() : void
    + utkozott(masik : Jarmu) : void
}

enum UtTipus {
    NORMAL
    ALAGUT
    HID
    KERESZTEZODES
}

enum Epulet {
    MEGALLO
    HAZ
    MUNKAHELY
    BAZIS
}

abstract class Jarmu {
  - pozicio: Utszakasz
  + {abstract} halad(cel: Utszakasz): void
  + getPozicio(): Utszakasz
}

class Utszakasz {
    - ho : int
    - jeg : int
    - havonAthaladt : int
    - kozlekedoJarmu : Jarmu
    - felrehuzodottJarmu : Jarmu
    - szakaszElore : Utszakasz
    - szakaszBalra : Utszakasz
    - szakaszJobbra : Utszakasz
    + idojarasFrissites() : void
    + foglaltE() : boolean
    + letakaritas() : void
    + belep(jarmu: Jarmu) : void
    + jarmuElore() : boolean
    + jarmuSavotvalt_jobbra() : boolean
    + jarmuSavotvalt_balra() : boolean
    + getEpulet() : Epulet
}

Utszakasz o-- "1" UtTipus 
Utszakasz o-- "0..1" Epulet 

abstract class Jatekos {
  - nev: String
  - egyenleg: int
  + penztKap(osszeg: int): void
  + getEgyenleg(): int
}

class Buszvezeto {
  - sajatBusz: Busz
  + utvonalatValtoztat(ujCel: Utszakasz): void
}

class Busz {
  - celAllomas: Utszakasz
  - hatralevoJavitasiIdo: int
  - vezerlo: Buszvezeto
  - kovetkezoLepes: Utszakasz
  + halad(cel: Utszakasz): void
  + utkozott(masik: Jarmu): void
  + kicsuszik(): void
  + celbaErt(): void
  + idoEltelt(): void
  + setCelAllomas(ujCel: Utszakasz): void
  + setKovetkezoLepes(ujLepes: Utszakasz): void
  + getKovetkezoLepes(): Utszakasz
  + felszall(bv: Buszvezeto)
}

Jatekos <|-- Buszvezeto
Jarmu <|-- Busz

ILepheto <|.. Busz
ICsuszhat <|.. Busz

Busz "1" -right- "1" Buszvezeto 

' --- Nyilak a csapattárs stílusához igazítva ---
Jarmu --> "1" Utszakasz : pozicio >
Busz --> "1" Utszakasz : celAllomas >
Buszvezeto ..> Utszakasz : kijelöli >
@enduml
