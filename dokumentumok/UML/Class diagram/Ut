@startuml
skinparam classAttributeIconSize 0

enum Epulet {
    MEGALLO
    HAZ
    MUNKAHELY
    BAZIS
}

class Utszakasz {
    - ho: int
    - jeg: int
    - zuzottKo: boolean
    - havonAthaladt: int
    - kozlekedoJarmu: Jarmu
    - felrehuzodottJarmu: Jarmu
    - szuloUttest: Uttest
    --
    + jarmutElore(): boolean
    + jarmuSavotvalt_jobbra(): boolean
    + jarmuSavotvalt_balra(): boolean
    + jarmutElore(): boolean
    + belep(Jarmu): void
    + idojarasFrissites(): void
    + foglaltE(): boolean
    + letakaritas(): void
    + getEpulet(): Epulet
    
}

class Alagutszakasz extends Utszakasz {
  --
  +idojarasFrissites: void
}

class Hidszakasz extends Utszakasz {
  --
  +idojarasFrissites(): void
}

class Uttest {
    - savok: List<List<Utszakasz>>
    --
    + balraSorolasLehetseges(jelenlegi: Utszakasz): boolean
    + jobbraSorolasLehetseges(jelenlegi: Utszakasz): boolean
    + jarmutElore(jelenlegi: Utszakasz): boolean
}


class Keresztezodes {
    - kijaratok: List<Uttest>
    --
    + Keresztezodes(type: UtTipus)
    + kijaratHozzaadas(uttest: Uttest)
}


' Kapcsolatok
Uttest *-- "1..*" Utszakasz : tartalmaz
Keresztezodes --|> Uttest : öröklődik
Utszakasz o-- Epulet : ehhez tartozik



@enduml
