@startuml
title: Busz várakozik javítás közben
skinparam participant {
    BackgroundColor White
    BorderColor Black
}

' A Skeleton (vagy Tesztelő) indítja a konkrét tesztlépést
participant ":Skeleton" as skeleton
participant "o1: Ora" as o1
participant "b1: Busz" as b1

' A Skeleton kiadja a parancsot az órának
skeleton -> o1 : tick()
activate o1

' Az óra végzi a dolgát
o1 -> b1 : idoEltelt()
activate b1

b1 --> o1
deactivate b1

' Visszatérünk a Skeletonhoz, a tesztlépés véget ért
o1 --> skeleton
deactivate o1
@enduml
