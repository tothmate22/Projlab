@startuml
hide footbox
skinparam sequenceMessageAlign center
title: "Sikeresn célba ér a busz"
actor "Aktor" as actor
participant ":Skeleton" as skel
participant "b1:Busz" as b1
participant "u_megallo:Utszakasz" as u_megallo
participant "bv1:Buszvezeto" as bv1

note over u_megallo : Ez az útszakasz fixen a \nbusz végállomása (MEGALLO).

actor -> skel : 1: Busz célba ér teszt
activate skel

' A tesztben fixen a megállót adjuk át, nem kérdezünk vissza
skel -> b1 : halad(u_megallo)
activate b1

' A busz konzultál az úttal (ami fixen szabad)
b1 -> u_megallo : fogaltE()
activate u_megallo
u_megallo --> b1 : false
deactivate u_megallo

' Belépés
b1 -> u_megallo : belep(b1)
activate u_megallo
u_megallo --> b1
deactivate u_megallo

' FIX ELLENŐRZÉS: Mivel tudjuk, hogy célba értünk, fut a logika
note over b1 : belső ellenőrzés:\npozicio == celAllomas ? IGEN
b1 -> b1 : celbaErt()
activate b1

b1 -> bv1 : penztKap(100)
activate bv1
bv1 --> b1
deactivate bv1

deactivate b1

b1 --> skel : true
deactivate b1

skel --> actor : Teszt sikeres
deactivate skel

@enduml
