@startuml
title: Célba ér a busz
skinparam participant {
    BackgroundColor White
    BorderColor Black
}

participant ":Skeleton" as skeleton
participant "u_jelen: Utszakasz" as u1
participant "u_cel: Utszakasz" as u2
participant "b1: Busz" as b1
participant "bv1: Buszvezeto" as bv1

' 1. A Skeleton indít (mert ez egy teszteset)
skeleton -> u1 : jarmuElore()
activate u1

' 2. Az út ellenőrzi a szomszédját (Analízis metódus!)
u1 -> u2 : foglaltE()
activate u2
u2 --> u1 : false
deactivate u2

' 3. Az út átteszi a buszt az új szakaszra
u1 -> u2 : belep(b1)
activate u2
u2 --> u1
deactivate u2

' 4. A busz észleli, hogy célba ért
u1 -> b1 : celbaErt()
activate b1

' 5. Jutalomosztás (ahogy a képeden is volt, nagyon helyesen!)
b1 -> bv1 : penztKap(100)
activate bv1
bv1 --> b1
deactivate bv1

b1 --> u1
deactivate b1

u1 --> skeleton : true
deactivate u1
@enduml
