{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Java Project",
            "type": "shell",
            "command": "bash",
            "args": [
                "-c",
                "mkdir -p bin && javac -encoding UTF-8 -d bin src/*.java"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": [
                "$javac"
            ]
        }
    ]
}
